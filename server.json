{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.samuelbushi/uizze",
  "title": "UIZZE",
  "description": "STOP UI SLOP. 800,000+ real web and iOS screens plus a hard finish gate for Codex, Claude Code, Cursor, and Copilot.",
  "websiteUrl": "https://uizze.com",
  "icons": [
    {
      "src": "https://uizze.com/brand/icons/uizze-web-app-icon-512x512.png",
      "mimeType": "image/png",
      "sizes": ["512x512"]
    }
  ],
  "repository": {
    "url": "https://github.com/aislon/uizze-mcp",
    "source": "github"
  },
  "version": "1.1.7",
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://uizze.com/mcp",
      "headers": [
        {
          "name": "Authorization",
          "description": "Enter Bearer followed by your UIZZE agent token.",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
